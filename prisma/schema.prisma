// ─────────────────────────────────────────────────────────────────────────────
// Schéma de la base TCIT — FIDÈLE à la base HFSQL « STCA M » (explorée le
// 15/06/2026, cf. mémoire project-stca-database-schema). Objectif : importer
// l'ancienne base SANS PERTE et remplacer le localStorage (plafonné ~5 Mo) qui
// ne peut pas contenir les 338 075 enregistrements réels.
//
// Provider SQLite pour démarrer (fichier local, zéro serveur). Le passage à
// PostgreSQL en client/serveur (Phase 4) se fera en changeant ce provider —
// les modèles et le code Prisma restent les mêmes.
//
// Décisions validées par l'utilisateur (22/07/2026) :
//  1. Archives = UNE SEULE table (dateArchivage nul = actif, rempli = archivé)
//     au lieu des 2 tables STCA — colle au concept « l'archivage ne sort rien
//     du système ». Les 2 tables STCA fusionnent à l'import.
//  2. Mots de passe en clair pour l'instant (hachage branché en Phase 3).
//  3. Portée = TOUT STCA M, même les champs pas encore affichés, pour un
//     import sans perte.
//
// Note SQLite : pas de types natifs @db.VarChar ni d'enum (montants en Int —
// F CFA sans centimes). Les FK « souples » de l'Enregistrement (categorieRang,
// codeTransit) sont des valeurs indexées et non des contraintes dures, pour un
// import robuste de données héritées — comme STCA (clés « avec doublon »).
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Référentiels ──────────────────────────────────────────────

/// ← CATVEH (RANG + TypeVehicule). Le « Rang dans la combos » = RANG.
model CategorieVehicule {
  id   Int    @id @default(autoincrement())
  rang Int    @unique
  nom  String

  @@map("categorie_vehicule")
}

/// ← ZoneImportation (bureaux frontière). + couleur de plaque (ajout TCIT).
model Destination {
  id             Int     @id @default(autoincrement())
  code           String  @unique // AFO, CK, KA, NO...
  nom            String // Afolé, Cinkassé...
  lettre         String  @default("") // lettre de la plaque
  tarif          Int     @default(10000)
  numImmatActuel Int     @default(0) // compteur immat. par frontière
  couleur        String  @default("#2563EB") // couleur de la plaque pré-imprimée
  contact        String? // ZoneImportation.Contact
  description    String? // ZoneImportation.Description

  @@map("destination")
}

/// ← TYPEVEH / TypVehIndex (marques et modèles).
model MarqueModele {
  id      Int     @id @default(autoincrement())
  marque  String
  modele  String?
  libelle String  @unique // « TOYOTA COROLLA » (MarqueModele combiné)

  @@map("marque_modele")
}

/// ← PAYS (pour Pays de résidence / de destination).
model Pays {
  id        Int     @id @default(autoincrement())
  nom       String  @unique
  iso3      String? // ISO_Alpha3
  actif     Boolean @default(true)
  continent String?
  codeOTR   String?

  @@map("pays")
}

// ─── Assurance ─────────────────────────────────────────────────

/// ← TYPEASSURANCE (assureur / groupement d'assurance).
model Assureur {
  id          Int     @id @default(autoincrement())
  nom         String
  coordonnees String?

  tarifs TarifAssurance[]

  @@map("assureur")
}

/// ← VEHASSURANCE (tarifs par catégorie) + détail des primes (ajout TCIT).
model TarifAssurance {
  id            Int @id @default(autoincrement())
  assureurId    Int
  categorieRang Int // ← CATVEH.RANG (souple)
  tarif         Int // TTC payé par le client
  taxe          Int // TaxeAssurance
  commissionPct Int // % STCA sur le brut
  // Détail des primes constituant le tarif (dérivé à l'import si absent)
  rc           Int @default(0)
  cedeao       Int @default(0)
  individuelle Int @default(0)
  accessoires  Int @default(0)

  assureur Assureur @relation(fields: [assureurId], references: [id])

  @@unique([assureurId, categorieRang])
  @@map("tarif_assurance")
}

// ─── Enregistrements (table UNIQUE : actifs + archivés) ─────────

/// ← ENREGISTREMENTS + ARCHIVE fusionnées (dateArchivage nul = actif).
model Enregistrement {
  id                      Int       @id @default(autoincrement())
  numRef                  Int       @unique // NumRef (clé unique STCA)
  nomPrenomProprio        String
  adresseProprio          String?
  ancienneImmatriculation String? // AncienneImmatriculation
  dateAncienneCG          DateTime? // DateAncienneCG
  categorieRang           Int? // ← CATVEH.RANG (souple)
  codeTransit             String // ← CodeTransit (souple)
  maisonTransit           String?
  nomDuParc               String?
  marqueModele            String // texte, comme STCA
  vin                     String    @unique // Vin_Vehicule (châssis)
  numTri                  String?
  numImmatriculation      String
  montant                 Int       @default(10000) // Montant_Enregistrement
  dateEnreg               DateTime  @default(now())
  flagSortie              Boolean   @default(false)
  dateSortie              DateTime?
  nomUtilisateur          String? // agent qui a saisi (texte, comme STCA)
  assureurId              Int? // ← IDTYPEASSURANCE
  // Archivage : nul = actif, rempli = archivé (rien ne sort du système)
  dateArchivage DateTime?
  archivePar    String?

  @@unique([numImmatriculation, codeTransit]) // couple unique (Compo_ImmaCode)
  @@index([dateEnreg])
  @@index([codeTransit, dateEnreg])
  @@index([flagSortie, dateSortie])
  @@index([dateArchivage])
  @@map("enregistrement")
}

// ─── Système ───────────────────────────────────────────────────

/// Comptes de connexion (mot de passe en clair pour l'instant — hachage Phase 3).
model Utilisateur {
  id             Int     @id @default(autoincrement())
  login          String  @unique
  motDePasse     String
  nom            String
  administrateur Boolean @default(false)
  compteActif    Boolean @default(true)

  @@map("utilisateur")
}

/// Réglages singletons (compteur de référence, mise en service assurances,
/// mot de passe de forçage admin...) sous forme clé → valeur.
model Parametre {
  cle    String @id
  valeur String

  @@map("parametre")
}
